# Supaband Environment Variables
# Copy to .env and fill in real values. Or just run ./setup.sh

# ── LLM Provider (OpenAI-compatible) ─────────────────────────────
# Any OpenAI-compatible API: OpenAI, AI/ML API, Featherless, Groq, etc.
OPENAI_API_KEY=your-o...1
# For AI/ML API use:   https://api.aimlapi.com/v1
# For Featherless use:  https://api.featherless.ai/v1
# For Groq use:         https://api.groq.com/openai/v1

# ── Band Human API Key ───────────────────────────────────────────
# Get this from https://app.band.ai → Settings → API Keys
# Needed for: automated setup (setup.py) and on-demand worker creation
BAND_HUMAN_API_KEY=your-band-human-api-key
